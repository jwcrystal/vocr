#!/usr/bin/env bash
# vocr-server — manage PaddleOCR-VL inference server (mlx_vlm.server)
#
# Usage:
#   vocr-server start    # launch server in background
#   vocr-server stop     # stop server
#   vocr-server status   # check if running
#   vocr-server restart  # restart

set -euo pipefail

PORT="${VOCR_PORT:-8765}"
PROFILE="${VOCR_PROFILE:-paddleocr-vl}"

case "$PROFILE" in
  paddleocr-vl) MODEL="PaddlePaddle/PaddleOCR-VL-1.6" ;;
  glm-ocr)      MODEL="mlx-community/GLM-OCR-bf16" ;;
  *)            MODEL="$VOCR_PROFILE" ;;  # treat as raw model name
esac
DATA_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PID_FILE="$DATA_DIR/server.pid"
LOG_FILE="$DATA_DIR/server.log"

mkdir -p "$DATA_DIR"

is_running() {
  [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

wait_ready() {
  for i in $(seq 1 60); do
    if python3 -c "
import urllib.request, sys
try:
    urllib.request.urlopen('http://127.0.0.1:$PORT/v1/models', timeout=1)
except Exception:
    sys.exit(1)
" 2>/dev/null; then
      return 0
    fi
    sleep 1
  done
  return 1
}

case "${1:-status}" in
  start)
    if is_running; then
      echo "Already running (PID: $(cat "$PID_FILE"), port: $PORT)"
      exit 0
    fi
    echo "Starting server (model: $MODEL, port: $PORT)..."
    mlx_vlm.server --model "$MODEL" --port "$PORT" --host 127.0.0.1 \
      > "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    echo -n "Waiting for model to load"
    if wait_ready; then
      echo " OK"
      echo "Server ready at http://127.0.0.1:$PORT"
    else
      echo "FAILED"
      echo "Check log: $LOG_FILE"
      tail -20 "$LOG_FILE" >&2 || true
      rm -f "$PID_FILE"
      exit 1
    fi
    ;;

  stop)
    if is_running; then
      PID=$(cat "$PID_FILE")
      kill "$PID" 2>/dev/null || true
      sleep 1
      kill -9 "$PID" 2>/dev/null || true
      rm -f "$PID_FILE"
      echo "Stopped"
    else
      echo "Not running"
      rm -f "$PID_FILE"
    fi
    ;;

  restart)
    "$0" stop || true
    sleep 1
    "$0" start
    ;;

  status)
    if is_running; then
      echo "Running (PID: $(cat "$PID_FILE"), port: $PORT, model: $MODEL)"
    else
      echo "Not running"
      exit 1
    fi
    ;;

  *)
    echo "Usage: vocr-server {start|stop|restart|status}" >&2
    exit 1
    ;;
esac
